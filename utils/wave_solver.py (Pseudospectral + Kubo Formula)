"""
Advanced Polariton Wave Solver
- Pseudospectral method (FFT-based)
- Graphene conductivity using Kubo formula approximation
- hBN anisotropic permittivity for phonon polariton
- Serpentine waveguide with path-dependent phase
"""

import numpy as np
from scipy.fft import fft2, ifft2, fftfreq

class PolaritonWaveSolver:
    def __init__(self, config):
        self.config = config
        
        # Grid setup
        self.Nx, self.Ny = config.Nx, config.Ny
        self.Lx, self.Ly = config.Lx, config.Ly
        self.dx = self.Lx / self.Nx
        self.dy = self.Ly / self.Ny
        
        self.x = np.linspace(-self.Lx/2, self.Lx/2, self.Nx)
        self.y = np.linspace(-self.Ly/2, self.Ly/2, self.Ny)
        self.X, self.Y = np.meshgrid(self.x, self.y, indexing='xy')
        
        # Fourier space
        self.kx = 2 * np.pi * fftfreq(self.Nx, d=self.dx)
        self.ky = 2 * np.pi * fftfreq(self.Ny, d=self.dy)
        self.KX, self.KY = np.meshgrid(self.kx, self.ky, indexing='xy')
        self.K2 = self.KX**2 + self.KY**2
        
        # Physical parameters
        self.freq = 5.0  # THz
        self.omega = 2 * np.pi * self.freq * 1e12
        self.k0 = self.omega / 3e8 * 1e6  # μm⁻¹ 단위
        
        # Material models
        self.graphene_sigma = self._kubo_conductivity()
        self.hbn_epsilon = self._hbn_permittivity()
        
        # Geometry
        self.waveguide_mask = self._create_serpentine_waveguide()
        self.hbn_mask = self._create_hbn_coupling_zone()
        
        print(f"PolaritonWaveSolver initialized @ {self.freq} THz")

    def _kubo_conductivity(self, Ef=0.4, gamma=10e-3, T=300):
        """Simplified Kubo formula for graphene conductivity (intraband dominant)"""
        e = 1.60217662e-19
        hbar = 1.0545718e-34
        kB = 1.380649e-23
        
        # Intraband term (dominant in THz)
        sigma_intra = (1j * e**2 * Ef) / (np.pi * hbar**2 * (self.omega + 1j * gamma))
        
        # Convert to effective permittivity contribution
        # For thin layer approximation
        effective_eps = 1 + 1j * sigma_intra / (self.omega * 8.85e-12 * 0.34e-9)  # 0.34 nm thickness
        return effective_eps

    def _hbn_permittivity(self):
        """Anisotropic hBN permittivity in Reststrahlen band (phonon polariton)"""
        # Strong negative permittivity region for phonon polariton
        eps_xx = 4.5 + 3.5j   # in-plane (strong response)
        eps_yy = 2.8 + 1.2j   # out-of-plane
        return {'xx': eps_xx, 'yy': eps_yy}

    def _create_serpentine_waveguide(self):
        """Thick serpentine graphene waveguide"""
        y_path = (0.8 * np.sin(0.7 * self.X) + 
                  0.35 * np.sin(1.9 * self.X) + 
                  0.12 * self.X)
        
        thickness = 1.8
        mask = np.abs(self.Y - y_path) < thickness
        # Additional modulation for realistic waveguide feel
        mask |= np.abs(self.Y - (y_path + 0.7 * np.sin(0.4 * self.X))) < 0.8
        return mask.astype(float)

    def _create_hbn_coupling_zone(self):
        """Rectangular hBN slab for phonon polariton hybridization"""
        mask = np.zeros((self.Ny, self.Nx), dtype=float)
        x_c, y_c = 7.5, 0.0
        w, h = 13.0, 7.5
        region = (np.abs(self.X - x_c) < w/2) & (np.abs(self.Y - y_c) < h/2)
        mask[region] = 1.0
        return mask

    def _get_path_phase(self, phi_source, source_pos):
        """Path-dependent phase accumulation along serpentine path"""
        dist = np.sqrt((self.X - source_pos[0])**2 + (self.Y - source_pos[1])**2)
        serp_mod = 0.45 * np.sin(1.3 * self.X) + 0.25 * np.sin(2.8 * self.X)
        phase = self.k0 * 1.85 * dist + serp_mod + phi_source  # plasmon effective index ~1.85
        return phase

    def propagate(self, phi_A=0.0, phi_B=np.pi, amp_A=1.0, amp_B=0.58):
        """Main propagation with two sources"""
        E = np.zeros((self.Ny, self.Nx), dtype=complex)
        
        # Source A
        phase_A = self._get_path_phase(phi_A, self.config.source_A_pos)
        E += amp_A * np.exp(1j * phase_A) * self.waveguide_mask
        
        # Source B
        phase_B = self._get_path_phase(phi_B, self.config.source_B_pos)
        E += amp_B * np.exp(1j * phase_B) * self.waveguide_mask
        
        # Apply hBN hybridization (phonon polariton enhancement)
        E[self.hbn_mask > 0] *= (1.2 + 1.1j)   # strong confinement + loss
        
        # Graphene loss & plasmon damping
        damping = np.exp(-0.12 * np.abs(self.X) / self.Lx)
        E *= damping
        
        # Pseudospectral propagation
        E_fft = fft2(E)
        
        # Dispersion + damping in k-space
        k_damping = np.exp(-0.025 * np.sqrt(self.K2))
        phase_prop = np.exp(1j * 0.4 * np.sqrt(self.K2))
        
        E_fft *= k_damping * phase_prop
        E = ifft2(E_fft)
        
        return E
